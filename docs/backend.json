
{
  "entities": {
    "Family": {
      "title": "Family",
      "description": "The root document for a family unit.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "inviteCode": { "type": "string" },
        "settings": {
          "type": "object",
          "properties": {
            "timezone": { "type": "string" },
            "currency": { "type": "string" },
            "familyMotto": { "type": "string" },
            "publicHolidaysEnabled": { "type": "boolean" },
            "schoolTermsEnabled": { "type": "boolean" }
          }
        },
        "weeklySummaryLastSent": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "inviteCode"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended user information stored in Firestore.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "familyId": { "type": "string" },
        "role": { "type": "string", "enum": ["parent", "child", "teen", "grandparent", "admin"] },
        "avatarUrl": { "type": "string" },
        "points": { "type": "number" },
        "streakDays": { "type": "number" },
        "preferences": {
          "type": "object",
          "properties": {
            "theme": { "type": "string" },
            "notificationsEnabled": { "type": "boolean" },
            "locationSharingEnabled": { "type": "boolean" }
          }
        }
      },
      "required": ["displayName", "familyId", "role"]
    },
    "Event": {
      "title": "Event",
      "description": "Calendar events for work, school, church, etc.",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["work", "school", "church", "sports", "medical", "vacation", "holiday", "other"] },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "assignedTo": { "type": "array", "items": { "type": "string" } },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "isRecurring": { "type": "boolean" },
        "color": { "type": "string" }
      }
    },
    "Chore": {
      "title": "Chore",
      "description": "Household tasks with points and rotation.",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "title": { "type": "string" },
        "assignedTo": { "type": "string" },
        "frequency": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "pointsReward": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "done"] },
        "rotationEnabled": { "type": "boolean" }
      }
    },
    "Recipe": {
      "title": "Recipe",
      "description": "Family recipes with ingredients and instructions.",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "title": { "type": "string" },
        "ingredients": { "type": "array", "items": { "$ref": "#/backend/entities/Ingredient" } },
        "instructions": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "photoUrl": { "type": "string" },
        "prepTime": { "type": "string" },
        "servings": { "type": "number" }
      }
    },
    "MealPlan": {
      "title": "Meal Plan",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "weekStart": { "type": "string", "format": "date" },
        "days": { "type": "object" },
        "generatedShoppingItems": { "type": "array", "items": { "type": "string" } }
      }
    },
    "ShoppingList": {
      "title": "Shopping List",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "name": { "type": "string" },
        "items": { "type": "array", "items": { "$ref": "#/backend/entities/ShoppingListItem" } },
        "isAutoGenerated": { "type": "boolean" }
      }
    },
    "ShoppingListItem": {
      "title": "Shopping List Item",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "category": { "type": "string" },
        "checked": { "type": "boolean" }
      }
    },
    "Ingredient": {
      "title": "Ingredient",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "category": { "type": "string" }
      }
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial records for expenses and allowances.",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["allowance", "expense", "savings", "pocketMoney"] },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" }
      }
    },
    "Todo": {
      "title": "Todo",
      "description": "Shared or private tasks.",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "title": { "type": "string" },
        "isShared": { "type": "boolean" },
        "assignedTo": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in-progress", "done"] },
        "priority": { "type": "string", "enum": ["high", "medium", "low"] }
      }
    },
    "Homework": {
      "title": "Homework",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "childId": { "type": "string" },
        "subject": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string" }
      }
    },
    "HealthLog": {
      "title": "Health Log",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "value": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      }
    },
    "HealthProfile": {
      "title": "Health Profile",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "userId": { "type": "string" },
        "allergies": { "type": "array", "items": { "type": "string" } },
        "medications": { "type": "array", "items": { "type": "string" } },
        "bloodType": { "type": "string" }
      }
    },
    "FaithEntry": {
      "title": "Faith Entry",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "prayerPoints": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Celebration": {
      "title": "Celebration",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "type": { "type": "string", "enum": ["birthday", "anniversary", "graduation", "other"] },
        "date": { "type": "string", "format": "date" },
        "name": { "type": "string" },
        "giftIdeas": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Post": {
      "title": "Family Post",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "authorId": { "type": "string" },
        "type": { "type": "string" },
        "content": { "type": "string" },
        "mediaUrls": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Message": {
      "title": "Family Message",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "fromUser": { "type": "string" },
        "channel": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Note": {
      "title": "Family Note",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "color": { "type": "string" },
        "isPinned": { "type": "boolean" }
      }
    },
    "GameProgress": {
      "title": "Game Progress",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "userId": { "type": "string" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "currentLevel": { "type": "number" },
        "weeklyPoints": { "type": "number" }
      }
    },
    "FamilyReward": {
      "title": "Family Reward",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "name": { "type": "string" },
        "pointsCost": { "type": "number" },
        "redeemedBy": { "type": "string" }
      }
    },
    "Pet": {
      "title": "Pet",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "feedingSchedule": { "type": "string" }
      }
    },
    "Trip": {
      "title": "Trip",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "destination": { "type": "string" },
        "dates": { "type": "object" },
        "packingList": { "type": "array", "items": { "type": "object" } }
      }
    },
    "EmergencyDocument": {
      "title": "Emergency Document",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "title": { "type": "string" },
        "fileUrl": { "type": "string" },
        "type": { "type": "string" },
        "accessRoles": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Hobby": {
      "title": "Hobby",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "progress": { "type": "object" }
      }
    },
    "SleepLog": {
      "title": "Sleep Log",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "hours": { "type": "number" },
        "quality": { "type": "string" }
      }
    },
    "LocationShare": {
      "title": "Location Share",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "userId": { "type": "string" },
        "lastLocation": { "type": "object" },
        "sharingEnabled": { "type": "boolean" }
      }
    },
    "WishlistItem": {
      "title": "Wishlist Item",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "link": { "type": "string" },
        "status": { "type": "string", "enum": ["want", "bought", "received"] },
        "priority": { "type": "string", "enum": ["high", "medium", "low"] }
      }
    },
    "LanguageProgress": {
      "title": "Language Progress",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "userId": { "type": "string" },
        "language": { "type": "string" },
        "currentLevel": { "type": "string" },
        "streakDays": { "type": "number" },
        "lastLessonDate": { "type": "string", "format": "date-time" },
        "vocabularyCount": { "type": "number" }
      }
    },
    "NewsArticle": {
      "title": "News Article",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "category": { "type": "string", "enum": ["announcement", "achievement", "event", "world"] },
        "date": { "type": "string", "format": "date-time" },
        "mediaUrl": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/families/{familyId}": {
      "schema": "Family",
      "description": "Root family documents."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and settings."
    },
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Family calendar events."
    },
    "/chores/{choreId}": {
      "schema": "Chore",
      "description": "Household chores."
    },
    "/recipes/{recipeId}": {
      "schema": "Recipe",
      "description": "Recipe box."
    },
    "/mealPlans/{planId}": {
      "schema": "MealPlan",
      "description": "Weekly meal plans."
    },
    "/shoppingLists/{listId}": {
      "schema": "ShoppingList",
      "description": "Grocery and shopping lists."
    },
    "/transactions/{txId}": {
      "schema": "Transaction",
      "description": "Family ledger."
    },
    "/todos/{todoId}": {
      "schema": "Todo",
      "description": "Family and private to-dos."
    },
    "/homework/{hwId}": {
      "schema": "Homework",
      "description": "School assignments."
    },
    "/healthLogs/{logId}": {
      "schema": "HealthLog",
      "description": "Wellness tracking."
    },
    "/healthProfiles/{userId}": {
      "schema": "HealthProfile",
      "description": "Medical history."
    },
    "/faithEntries/{entryId}": {
      "schema": "FaithEntry",
      "description": "Church and faith activities."
    },
    "/celebrations/{celebId}": {
      "schema": "Celebration",
      "description": "Birthdays and anniversaries."
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Family memories and social posts."
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Internal family messaging."
    },
    "/notes/{noteId}": {
      "schema": "Note",
      "description": "Quick memos and sticky notes."
    },
    "/gameProgress/{progressId}": {
      "schema": "GameProgress",
      "description": "Gamification stats."
    },
    "/familyRewards/{rewardId}": {
      "schema": "FamilyReward",
      "description": "Redeemable family rewards."
    },
    "/pets/{petId}": {
      "schema": "Pet",
      "description": "Pet care tracking."
    },
    "/trips/{tripId}": {
      "schema": "Trip",
      "description": "Travel planning."
    },
    "/emergencyVault/{docId}": {
      "schema": "EmergencyDocument",
      "description": "Secure document storage."
    },
    "/hobbies/{hobbyId}": {
      "schema": "Hobby",
      "description": "Personal interest tracking."
    },
    "/sleepLogs/{logId}": {
      "schema": "SleepLog",
      "description": "Rest tracking."
    },
    "/locationShares/{shareId}": {
      "schema": "LocationShare",
      "description": "Opt-in family tracking."
    },
    "/wishlist/{itemId}": {
      "schema": "WishlistItem",
      "description": "Family member wishlists."
    },
    "/languageProgress/{progressId}": {
      "schema": "LanguageProgress",
      "description": "Language learning stats."
    },
    "/news/{newsId}": {
      "schema": "NewsArticle",
      "description": "Family and world news feed."
    }
  }
}
