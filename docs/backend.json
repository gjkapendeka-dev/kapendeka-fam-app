
{
  "entities": {
    "Family": {
      "title": "Family",
      "description": "The root document for a family unit.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "inviteCode": { "type": "string" },
        "settings": {
          "type": "object",
          "properties": {
            "timezone": { "type": "string" },
            "currency": { "type": "string" },
            "familyMotto": { "type": "string" },
            "publicHolidaysEnabled": { "type": "boolean" },
            "schoolTermsEnabled": { "type": "boolean" }
          }
        },
        "weeklySummaryLastSent": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "inviteCode"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended user information stored in Firestore.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "familyId": { "type": "string" },
        "role": { "type": "string", "enum": ["parent", "child", "teen", "grandparent", "admin"] },
        "avatarUrl": { "type": "string" },
        "points": { "type": "number" },
        "streakDays": { "type": "number" },
        "preferences": {
          "type": "object",
          "properties": {
            "theme": { "type": "string" },
            "notificationsEnabled": { "type": "boolean" },
            "locationSharingEnabled": { "type": "boolean" }
          }
        }
      },
      "required": ["displayName", "familyId", "role"]
    },
    "Poll": {
      "title": "Family Poll",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "question": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "votes": { "type": "object" },
        "status": { "type": "string", "enum": ["open", "closed"] },
        "createdBy": { "type": "string" }
      }
    },
    "Story": {
      "title": "AI Story",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "coverUrl": { "type": "string" },
        "characters": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Quest": {
      "title": "Universe Quest",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "steps": { "type": "array", "items": { "type": "object" } },
        "status": { "type": "string", "enum": ["active", "completed"] },
        "pointsReward": { "type": "number" }
      }
    },
    "VisionItem": {
      "title": "Vision Board Item",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "targetYear": { "type": "number" }
      }
    },
    "EcoLog": {
      "title": "Eco Impact Log",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "type": { "type": "string" },
        "value": { "type": "number" },
        "date": { "type": "string", "format": "date-time" }
      }
    },
    "ZenMoment": {
      "title": "Mindfulness Log",
      "type": "object",
      "properties": {
        "familyId": { "type": "string" },
        "userId": { "type": "string" },
        "duration": { "type": "number" },
        "mood": { "type": "string" }
      }
    },
    "Event": { "schema": "Event", "title": "Event", "type": "object", "properties": { "familyId": { "type": "string" }, "title": { "type": "string" }, "type": { "type": "string" }, "startTime": { "type": "string" }, "endTime": { "type": "string" }, "location": { "type": "string" }, "description": { "type": "string" } } },
    "Chore": { "schema": "Chore", "title": "Chore", "type": "object", "properties": { "familyId": { "type": "string" }, "title": { "type": "string" }, "assignedTo": { "type": "string" }, "pointsReward": { "type": "number" }, "status": { "type": "string" }, "dueDate": { "type": "string" } } },
    "Ritual": { "schema": "Ritual", "title": "Ritual", "type": "object", "properties": { "familyId": { "type": "string" }, "title": { "type": "string" }, "timeOfDay": { "type": "string" }, "pointsValue": { "type": "number" }, "description": { "type": "string" } } }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/families/{familyId}": { "schema": "Family", "description": "Root families." },
    "/users/{userId}": { "schema": "UserProfile", "description": "User profiles." },
    "/polls/{pollId}": { "schema": "Poll", "description": "Family polls." },
    "/stories/{storyId}": { "schema": "Story", "description": "AI created stories." },
    "/quests/{questId}": { "schema": "Quest", "description": "Family scavenger hunts." },
    "/visionBoard/{itemId}": { "schema": "VisionItem", "description": "Family dreams." },
    "/ecoLogs/{logId}": { "schema": "EcoLog", "description": "Sustainability logs." },
    "/zenMoments/{momentId}": { "schema": "ZenMoment", "description": "Mindfulness logs." },
    "/events/{eventId}": { "schema": "Event", "description": "Family calendar." },
    "/chores/{choreId}": { "schema": "Chore", "description": "Household chores." },
    "/rituals/{ritualId}": { "schema": "Ritual", "description": "Daily family habits." },
    "/recipes/{recipeId}": { "schema": "Recipe", "description": "Recipe box." },
    "/messages/{messageId}": { "schema": "Message", "description": "Internal family messaging." },
    "/notes/{noteId}": { "schema": "Note", "description": "Quick memos." },
    "/transactions/{txId}": { "schema": "Transaction", "description": "Family ledger." }
  }
}
